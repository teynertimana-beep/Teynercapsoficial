  <script>
    function abrirSlider(idGal, index) {
      const imgs = document.getElementById(idGal).getElementsByTagName('img');
      let html = '';
      for (let i = 0; i < imgs.length; i++) html += `<img src="${imgs[i].src}">`;
      const slider = document.getElementById('modal-slider');
      slider.innerHTML = html;
      document.getElementById('modal-container').style.display = 'flex';
      slider.scrollLeft = index * window.innerWidth;
    }
    function abrirSola(src) {
      document.getElementById('modal-slider').innerHTML = `<img src="${src}">`;
      document.getElementById('modal-container').style.display = 'flex';
    }
    function cerrarSlider() { document.getElementById('modal-container').style.display = 'none'; }
    function enviar(mod, id) {
